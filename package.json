{
	"name": "suikakeibo-viewer",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"stations": "bun run scripts/build-stations.ts",
		"build:pages": "bun -e \"process.env.BASE_PATH='/Suikakeibo-Viewer'; await Bun.$`bunx vite build`\""
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/geojson": "^7946.0.16",
		"@types/node": "^26.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"idb-keyval": "^6.3.0",
		"maplibre-gl": "^5.24.0"
	}
}
